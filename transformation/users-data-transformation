def clean_employment_status(col):
    col = col.astype(str).str.strip().str.lower()
    
    return col.replace({
        # --- EMPLOYED ---
        r".*empl[o0]yed.*": "Employed",

        # --- SELF-EMPLOYED ---
        r".*self[\s\-]?empl[o0]yed.*": "Self-Employed",
        r".*self[\s\-]?employd.*": "Self-Employed",

        # --- STUDENT ---
        r".*stud[e]?nt.*": "Student",
        r".*studnt.*": "Student",

        # --- RETIRED ---
        r".*ret[i]?r[e]?d.*": "Retired",
        r".*ret\.*$": "Retired",

        # --- UNEMPLOYED ---
        r".*un[\s\-]?empl[o0]yed.*": "Unemployed",
        r".*unemployd.*": "Unemployed",

        # --- FALLBACK ---
        r"^nan$": "Not Available",
        r"^$": "Not Available"
        
    }, regex=True)

users_data_df["employment_status"] = clean_employment_status(
