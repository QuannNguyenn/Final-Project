### In the address column, there are rows with fully capitalized addresses. This inconsistency should be addressed for easier address tracing during analysis
def transform_address(text):
    return re.sub(r'(\d+)(st|nd|rd|th)\b',
                  lambda x: x.group(1) + x.group(2).lower(),
                  text,
                  flags=re.IGNORECASE)

users_data_df['address'] = users_data_df['address'].str.title().apply(transform_address)

