#---------------------------------------------------------------------------------------------------------------
## Ingesting the data into the dimensional model
conn = pyodbc.connect(
    f'DRIVER={{ODBC Driver 17 for SQL Server}};SERVER={server};DATABASE={'dimensional_dwh'};Trusted_Connection=yes;'
)
cursor = conn.cursor()

## Function to load the df into sql

def load_df_to_sql(df, table_name, columns, chunksize=1000):
    placeholders = ", ".join(["?"] * len(columns))
    sql = f"INSERT INTO {table_name} ({', '.join(columns)}) VALUES ({placeholders})"

    cursor.fast_executemany = True
    total_rows = 0

    # Keep only needed columns and replace missing values
    df = df[columns].copy()
    df = df.replace({np.nan: None, "": None})

    df = df.astype(object).where(pd.notnull(df), None)

    for start in range(0, len(df), chunksize):
        chunk = df.iloc[start:start + chunksize]

        data = [
            tuple(x.item() if hasattr(x, "item") else x for x in row)
            for row in chunk.to_numpy()
        ]

        cursor.executemany(sql, data)
        conn.commit()

        total_rows += len(chunk)

    print(f"Inserted {total_rows} rows into {table_name}")


load_df_to_sql(
    df=mcc_data_df,
    table_name="mcc_data_transformed",
    columns= [
        "code",
        "description",
        "notes",
        "updated_by"
    ],
    chunksize=1
)

