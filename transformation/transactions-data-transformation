def clean_state_and_flag(col):
    col = (
        col.astype(str)
        .str.strip()
        .str.replace(r"\s+", " ", regex=True)
    )
    
    col = col.replace({"nan": pd.NA, "": pd.NA})
    
    # Normalize casing for matching
    upper_col = col.str.upper()
    
    # Map only state codes
    mapped = upper_col.map(state_map)
    
    # If not a code, keep original value
    mapped = mapped.fillna(col)
    
    # Standardize to title case
    cleaned = (
        mapped.astype(str)
        .str.strip()
        .str.title()
        .replace("Nan", pd.NA)
        .fillna("Not Available")
    )
    
    # Identify US states
    us_states = set(state_map.values())
    in_us = cleaned.isin(us_states)
    
    # Convert to string labels FIRST
    in_us = in_us.map({True: "True", False: "False"})

    # Handle missing
    in_us = in_us.astype("object")
    in_us[cleaned == "Not Available"] = "Not Available"

    return cleaned, in_us

