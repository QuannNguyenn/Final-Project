## amount
### This column has formatting inconsistency issue similar to credit_limit or income of the other tables. We can use a similar function to address that, but instead of int it should be returned as float to accoubnt
### the decimal points in the transaction
def clean_amount(col):
    s = col.astype(str).str.strip().str.lower()

    s = s.replace({
        "error_value": pd.NA,
        "limit_unknown": pd.NA,
        "unknown": pd.NA,
        "not available": pd.NA
    })

    cleaned_text = s.str.replace(r"[$,\s]", "", regex=True)

    k_mask = cleaned_text.str.fullmatch(r"-?\d+(\.\d+)?k", na=False)
    k_numeric = pd.to_numeric(
        cleaned_text.where(k_mask).str.replace("k", "", regex=False),
        errors="coerce"
    ) * 1000

    normal_numeric = pd.to_numeric(cleaned_text.where(~k_mask), errors="coerce")

    result = k_numeric.fillna(normal_numeric)

    remaining_mask = result.isna() & s.notna()
    if remaining_mask.any():
        from word2number import w2n

        def try_word_to_num(x):
            try:
                return w2n.word_to_num(str(x))
            except Exception:
                return np.nan

        word_numeric = s.where(remaining_mask).apply(try_word_to_num)
        result = result.fillna(word_numeric)

    result = result.abs()

    # float output
    return result.astype("Float64")

transactions_data_df["amount"] = clean_amount(transactions_data_df["amount"])
